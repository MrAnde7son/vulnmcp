# Files excluded from the .mcpb bundle (glob, like .gitignore).
# The bundle ships: dist/, recipes/, assets/, bin/, manifest.json, package.json,
# and PRODUCTION node_modules only. CI additionally runs `npm prune --omit=dev`.

# Source & tooling (dist/ is shipped instead of src/)
src/
tests/
scripts/
.github/
.git/
.vscode/
*.ts
*.map
tsconfig.json
vitest.config.*

# Build/CI artifacts
coverage/
.trivy-dl-*/
*.mcpb
.vulnmcp-cache/
.DS_Store

# Dev-only dependencies (belt-and-suspenders alongside `npm prune --omit=dev`)
node_modules/typescript/
node_modules/tsx/
node_modules/vitest/
node_modules/@vitest/
node_modules/vite/
node_modules/vite-node/
node_modules/esbuild/
node_modules/@esbuild/
node_modules/rollup/
node_modules/@rollup/
node_modules/@types/
node_modules/.cache/
node_modules/.bin/
